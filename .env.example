# Root environment example for local development.
# Copy to .env when local configuration is introduced.

ENVIRONMENT=local

# Backend defaults planned for the local skeleton.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./aud_generator.db
STORAGE_BACKEND=local
JOB_QUEUE_BACKEND=local
LOCAL_STORAGE_ROOT=storage
MAX_SPREADSHEET_ROWS_PER_SHEET=200

# Optional OCI Object Storage settings.
# Keep STORAGE_BACKEND=local for normal local development.
# Set STORAGE_BACKEND=oci only after configuring the OCI Python SDK config file.
OCI_BUCKET_NAME=
OCI_NAMESPACE=
OCI_REGION=
OCI_COMPARTMENT_OCID=
OCI_CONFIG_FILE=
OCI_PROFILE=
OCI_MULTIPART_UPLOAD_THRESHOLD_BYTES=52428800
OCI_MULTIPART_UPLOAD_PART_SIZE_BYTES=10485760
OCI_MULTIPART_UPLOAD_PARALLEL_WORKERS=4

# Optional OCI Queue settings.
# Keep JOB_QUEUE_BACKEND=local for normal local development.
# Set JOB_QUEUE_BACKEND=oci only after creating an OCI Queue and configuring SDK auth.
OCI_QUEUE_OCID=
OCI_QUEUE_ENDPOINT=

# Optional OCI Speech settings for media transcription.
# Requires STORAGE_BACKEND=oci because Speech reads media from Object Storage.
OCI_SPEECH_COMPARTMENT_OCID=
OCI_SPEECH_OUTPUT_BUCKET=
OCI_SPEECH_OUTPUT_PREFIX=projects/{project_id}/speech/
OCI_SPEECH_MODEL_TYPE=WHISPER_MEDIUM
OCI_SPEECH_LANGUAGE_CODE=en
OCI_SPEECH_TIMEOUT_SECONDS=1800
OCI_SPEECH_POLL_INTERVAL_SECONDS=10

# Optional OCI Document Understanding settings.
DOCUMENT_AI_PROVIDER=none
OCI_DOCUMENT_COMPARTMENT_OCID=
OCI_DOCUMENT_OUTPUT_BUCKET=
OCI_DOCUMENT_OUTPUT_PREFIX=projects/{project_id}/document_understanding/output/
OCI_DOCUMENT_REGION=
OCI_DOCUMENT_TIMEOUT_SECONDS=900
OCI_DOCUMENT_POLL_INTERVAL_SECONDS=10
OCI_DOCUMENT_ENABLE_DOCX=false
OCI_DOCUMENT_ENABLE_PPTX=false
OCI_DOCUMENT_ENABLE_XLSX=false
OCI_DOCUMENT_ENABLE_PDF=true
OCI_DOCUMENT_ENABLE_IMAGES=true

# Optional OCI Generative AI LLM settings.
# Keep LLM_PROVIDER=none until you explicitly want to test the wrapper.
# Use ENVIRONMENT=development to enable POST /dev/llm-test.
# For the OCI Python SDK chat flow, use LLM_PROVIDER=oci_genai_classic and set
# OCI_GENAI_REGION, OCI_GENAI_COMPARTMENT_OCID, OCI_GENAI_MODEL_ID,
# OCI_CONFIG_FILE, and OCI_PROFILE. OCI_GENAI_PROJECT_OCID and
# OCI_GENAI_API_KEY are not required for that flow.
LLM_PROVIDER=none
OCI_GENAI_REGION=
OCI_GENAI_MODEL_ID=
OCI_GENAI_COMPARTMENT_OCID=
# Optional, only for OCI Responses/OpenAI-compatible setups that use a project.
OCI_GENAI_PROJECT_OCID=
# Optional, only for OCI Responses/OpenAI-compatible development auth.
OCI_GENAI_API_KEY=
OCI_GENAI_MAX_INPUT_CHARS=200000
OCI_GENAI_TIMEOUT_SECONDS=120
OCI_GENAI_TEMPERATURE=1
OCI_GENAI_MAX_OUTPUT_TOKENS=16000
OCI_GENAI_RETRY_MAX_ATTEMPTS=4
OCI_GENAI_RETRY_BASE_SECONDS=2
OCI_GENAI_RETRY_MAX_SECONDS=20
SECTION_EVIDENCE_MAX_CHARS=30000
REQUIRE_LLM_ENHANCED_OPEN_POINTS=true
ALLOW_RAW_OPEN_POINTS_FALLBACK=true

# Frontend defaults planned for local development.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
